---
import { render } from "astro:content";
import { getDocsCollection } from "@/utils/get-docs-collection";
import DocPageContent from "@/components/doc-page-content.astro";
import { toRouteSlug } from "@/utils/slug";
import {
  buildNavTree,
  buildBreadcrumbs,
  flattenTree,
  findNode,
  loadCategoryMeta,
  collectAutoIndexNodes,
  isNavVisible,
  type NavNode,
} from "@/utils/docs";
import type { Heading } from "@/types/heading";
import { getNavSectionForSlug, getNavSubtree } from "@/utils/nav-scope";
import { getContentDir } from "@/config/i18n";
import { settings } from "@/config/settings";
import { docsUrl } from "@/utils/base";
import type { DocsEntry } from "@/types/docs-entry";

export async function getStaticPaths() {
  const localeDocs = await getDocsCollection("docs-ja");
  const baseDocs = await getDocsCollection("docs");

  // In production, exclude drafts. In dev, include them for preview.
  const filterDrafts = (docs: DocsEntry[]) =>
    import.meta.env.PROD ? docs.filter((doc) => !doc.data.draft) : docs;

  const filteredLocaleDocs = filterDrafts(localeDocs);
  const filteredBaseDocs = filterDrafts(baseDocs);

  // Build slug set from locale docs (locale takes priority)
  const localeSlugSet = new Set(
    filteredLocaleDocs.map((d) => d.data.slug ?? toRouteSlug(d.id)),
  );

  // Merge: locale docs first, then base docs for missing pages
  const allDocs = [
    ...filteredLocaleDocs,
    ...filteredBaseDocs.filter(
      (d) => !localeSlugSet.has(d.data.slug ?? toRouteSlug(d.id)),
    ),
  ];

  // Track which slugs are fallback (from base collection)
  const fallbackSlugs = new Set(
    filteredBaseDocs
      .filter((d) => !localeSlugSet.has(d.data.slug ?? toRouteSlug(d.id)))
      .map((d) => d.data.slug ?? toRouteSlug(d.id)),
  );

  // Merge category metadata: base first, locale overrides
  const baseCategoryMeta = loadCategoryMeta(settings.docsDir);
  const localeCategoryMeta = loadCategoryMeta(getContentDir("ja"));
  const categoryMeta = new Map([...baseCategoryMeta, ...localeCategoryMeta]);

  // Exclude unlisted pages from nav tree (used for sidebar, prev/next)
  const navDocs = allDocs.filter(isNavVisible);
  const tree = buildNavTree(navDocs, "ja", categoryMeta);
  // Full tree including unlisted pages (used for breadcrumbs)
  const fullTree = buildNavTree(allDocs, "ja", categoryMeta);

  // Regular doc pages
  const docPaths = allDocs.map((entry) => {
    const slug = entry.data.slug ?? toRouteSlug(entry.id);
    const isFallback = fallbackSlugs.has(slug);
    const navSection = getNavSectionForSlug(slug);
    const subtree = getNavSubtree(tree, navSection);
    const flat = flattenTree(subtree);
    const idx = flat.findIndex((n) => n.slug === slug);

    let prevNode = idx > 0 ? flat[idx - 1] : null;
    let nextNode = idx >= 0 && idx < flat.length - 1 ? flat[idx + 1] : null;

    // Apply frontmatter overrides
    if (entry.data.pagination_prev !== undefined) {
      if (entry.data.pagination_prev === null) {
        prevNode = null;
      } else {
        const found = findNode(tree, entry.data.pagination_prev);
        prevNode = found ?? prevNode;
      }
    }
    if (entry.data.pagination_next !== undefined) {
      if (entry.data.pagination_next === null) {
        nextNode = null;
      } else {
        const found = findNode(tree, entry.data.pagination_next);
        nextNode = found ?? nextNode;
      }
    }

    return {
      params: { slug },
      props: {
        entry,
        contentDir: isFallback ? settings.docsDir : getContentDir("ja"),
        isFallback,
        breadcrumbs: buildBreadcrumbs(fullTree, slug, "ja"),
        prev: prevNode,
        next: nextNode,
      },
    };
  });

  // Auto-generated index pages for categories without index.mdx
  const autoIndexPaths = collectAutoIndexNodes(tree).map((node) => ({
    params: { slug: node.slug },
    props: {
      entry: null,
      contentDir: getContentDir("ja"),
      isFallback: false,
      autoIndex: {
        ...node,
        children: node.children.map((c: NavNode) => ({
          ...c,
          href: c.href ?? docsUrl(c.slug, "ja"),
        })),
      },
      breadcrumbs: buildBreadcrumbs(fullTree, node.slug, "ja"),
      prev: null,
      next: null,
    },
  }));

  return [...docPaths, ...autoIndexPaths];
}

const {
  entry,
  contentDir,
  isFallback,
  breadcrumbs = [],
  prev,
  next,
  autoIndex,
} = Astro.props;

let Content: any;
let headings: Heading[] = [];

if (entry) {
  const rendered = await render(entry as any);
  Content = rendered.Content;
  headings = rendered.headings;
}

const slug = autoIndex
  ? autoIndex.slug
  : (entry!.data.slug ?? toRouteSlug(entry!.id));
---

<DocPageContent
  entry={entry}
  slug={slug}
  locale="ja"
  contentDir={contentDir}
  isFallback={isFallback}
  breadcrumbs={breadcrumbs}
  prev={prev}
  next={next}
  autoIndex={autoIndex}
  headings={headings}
  Content={Content}
/>
