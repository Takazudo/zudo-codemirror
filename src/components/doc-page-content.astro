---
/**
 * Shared rendering logic for all doc page templates (EN, JA, versioned EN/JA).
 *
 * Each page file remains responsible for data fetching (getStaticPaths),
 * locale-specific collection loading, and passing the right props here.
 */
import DocLayout from "@/layouts/doc-layout.astro";
import Note from "@/components/admonitions/note.astro";
import Tip from "@/components/admonitions/tip.astro";
import Info from "@/components/admonitions/info.astro";
import Warning from "@/components/admonitions/warning.astro";
import Danger from "@/components/admonitions/danger.astro";
import CategoryNav from "@/components/category-nav.astro";
import CategoryTreeNav from "@/components/category-tree-nav.astro";
import SiteTreeNavDemo from "@/components/site-tree-nav-demo.astro";
import Tabs from "@/components/tabs.astro";
import TabItem from "@/components/tab-item.astro";
import Details from "@/components/details.astro";
import HtmlPreview from "@/components/html-preview-wrapper.astro";
import Breadcrumb from "@/components/breadcrumb.astro";
import EditLink from "@/components/edit-link.astro";
import DocMetainfo from "@/components/doc-metainfo.astro";
import DocTags from "@/components/doc-tags.astro";
import { t } from "@/config/i18n";
import type { Locale } from "@/config/i18n";
import { settings } from "@/config/settings";
import type { NavNode } from "@/utils/docs";
import type { Heading } from "@/types/heading";
import type { DocsEntry } from "@/types/docs-entry";
import type { VersionConfig } from "@/config/settings-types";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface AutoIndexNode {
  slug: string;
  label: string;
  description?: string;
  children: NavNode[];
}

interface Props {
  /** The content entry, null for auto-index pages */
  entry: DocsEntry | null;
  /** Computed slug for the current page */
  slug: string;
  /** Locale for translations and URL generation */
  locale: Locale;
  /** Content directory path (for DocMetainfo and EditLink) */
  contentDir: string;
  /** Whether this page is a locale fallback from the base collection */
  isFallback?: boolean;
  /** Breadcrumb items */
  breadcrumbs?: BreadcrumbItem[];
  /** Previous page nav node */
  prev?: NavNode | null;
  /** Next page nav node */
  next?: NavNode | null;
  /** Auto-index node (for category pages without index.mdx) */
  autoIndex?: AutoIndexNode | null;
  /** Rendered headings from the content entry */
  headings?: Heading[];
  /** Rendered Content component from astro:content render() */
  Content?: any;
  /** Version slug for versioned pages */
  currentVersion?: string;
  /** Version banner for versioned pages */
  versionBanner?: VersionConfig["banner"];
}

const {
  entry,
  slug,
  locale,
  contentDir,
  isFallback = false,
  breadcrumbs = [],
  prev,
  next,
  autoIndex,
  headings = [],
  Content,
  currentVersion,
  versionBanner,
} = Astro.props;

const components = {
  Note,
  Tip,
  Info,
  Warning,
  Danger,
  CategoryNav,
  CategoryTreeNav,
  SiteTreeNavDemo,
  Tabs,
  TabItem,
  Details,
  HtmlPreview,
};
---

<DocLayout
  title={autoIndex ? autoIndex.label : entry!.data.title}
  description={autoIndex ? autoIndex.description : entry!.data.description}
  lang={locale}
  currentSlug={slug}
  headings={autoIndex ? [] : headings}
  unlisted={entry?.data?.unlisted}
  hideSidebar={entry?.data?.hide_sidebar}
  hideToc={entry?.data?.hide_toc}
  currentVersion={currentVersion}
  versionBanner={versionBanner}
>
  <Breadcrumb slot="breadcrumb" items={breadcrumbs} />
  {
    autoIndex ? (
      <Fragment>
        <h1 class="text-heading font-normal font-futura mb-vsp-xs">{autoIndex.label}</h1>
        {autoIndex.description && (
          <p class="mt-0 mb-vsp-lg text-subheading text-muted">
            {autoIndex.description}
          </p>
        )}
        <nav class="grid grid-cols-1 gap-x-hsp-lg gap-y-vsp-md sm:grid-cols-2">
          {autoIndex.children
            .filter((c: NavNode) => c.hasPage || c.children.length > 0)
            .map((child: NavNode) => (
              <a
                href={child.href}
                class="group block border border-muted bg-surface px-hsp-lg py-vsp-md hover:border-accent"
              >
                <span class="font-medium text-accent underline group-hover:underline">
                  {child.label}
                </span>
                {child.description && (
                  <span class="mt-vsp-2xs block text-small text-muted group-hover:underline decoration-muted">
                    {child.description}
                  </span>
                )}
              </a>
            ))}
        </nav>
      </Fragment>
    ) : (
      <Fragment>
        <h1 class="text-heading font-normal font-futura mb-vsp-xs">{entry!.data.title}</h1>
        {settings.docMetainfo && (
          <DocMetainfo
            filePath={`${contentDir}/${entry!.id}`}
            locale={locale}
          />
        )}

        {isFallback && !entry!.data.generated && (
          <div
            class="mb-vsp-md border border-info/30 bg-info/5 px-hsp-lg py-vsp-sm text-small text-muted rounded"
            role="note"
          >
            {t("doc.fallbackNotice", locale)}
          </div>
        )}

        {entry!.data.description && (
          <p class="mt-0 mb-vsp-lg text-subheading text-muted">
            {entry!.data.description}
          </p>
        )}

        {entry?.data?.tags && <DocTags tags={entry.data.tags} locale={locale} />}

        {Content && <Content components={components} />}

        {settings.editUrl && entry && (
          <div class="mt-vsp-xl mb-vsp-md border-t border-muted pt-vsp-md">
            <EditLink
              contentDir={contentDir}
              entryId={entry.id}
              locale={locale}
            />
          </div>
        )}

        <nav class="mt-vsp-2xl grid grid-cols-2 gap-hsp-xl">
          {prev ? (
            <a
              href={prev.href}
              class="group border border-muted rounded-lg p-hsp-lg hover:border-accent"
            >
              <div class="flex items-center gap-hsp-xs text-caption text-muted mb-vsp-2xs">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-[1.125rem] w-[1.125rem]"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 19l-7-7 7-7"
                  />
                </svg>
                <span class="no-underline">{t("nav.previous", locale)}</span>
              </div>
              <p class="text-small font-semibold underline group-hover:text-accent">
                {prev.label}
              </p>
            </a>
          ) : (
            <div />
          )}
          {next ? (
            <a
              href={next.href}
              class="group border border-muted rounded-lg p-hsp-lg hover:border-accent text-right"
            >
              <div class="flex items-center justify-end gap-hsp-xs text-caption text-muted mb-vsp-2xs">
                <span class="no-underline">{t("nav.next", locale)}</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-[1.125rem] w-[1.125rem]"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </div>
              <p class="text-small font-semibold underline group-hover:text-accent">
                {next.label}
              </p>
            </a>
          ) : (
            <div />
          )}
        </nav>
      </Fragment>
    )
  }
</DocLayout>
