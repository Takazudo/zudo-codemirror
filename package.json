{
  "name": "zudo-codemirror",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "// ── Dev ─────────────────────────────────────────": "",
    "predev": "lsof -ti :8847 | xargs kill 2>/dev/null; true",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "// ── CM6 bundle ──────────────────────────────────": "",
    "build:cm6": "bash scripts/build-cm6-bundle.sh",
    "// ── Code quality ────────────────────────────────": "",
    "format:md": "pnpm dlx @takazudo/mdx-formatter --write 'src/content/**/*.{md,mdx}'",
    "format:md:check": "pnpm dlx @takazudo/mdx-formatter --check 'src/content/**/*.{md,mdx}'",
    "// ── Validation ──────────────────────────────────": "",
    "b4push": "bash scripts/run-b4push.sh"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.0",
    "@astrojs/react": "^4.4.0",
    "@shikijs/transformers": "^4.0.0",
    "astro": "^5.18.0",
    "clsx": "^2.1.0",
    "diff": "^8.0.4",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.0",
    "mermaid": "^11.13.0",
    "minisearch": "^7.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "remark-directive": "^3.0.0",
    "shiki": "^4.0.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-javascript": "^6.2.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.0",
    "@codemirror/language-data": "^6.5.0",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.0",
    "@codemirror/view": "^6.39.0",
    "@lezer/highlight": "^1.2.0",
    "@replit/codemirror-vim": "^6.3.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/diff": "^8.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "codemirror": "^6.0.0",
    "esbuild": "^0.25.0",
    "lefthook": "^1.11.0",
    "pagefind": "^1.4.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20.0"
  },
  "packageManager": "pnpm@10.6.5",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "sharp"
    ]
  }
}
